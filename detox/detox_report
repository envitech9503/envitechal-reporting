    const req_pip = await fetch('https://api.ipify.org?format=json');
    var public_ip = await req_pip.json();
    public_ip = public_ip.ip ? public_ip.ip : null;
    if (public_ip) {
        let url = `https://ipinfo.io/${public_ip}/json?token=fdc5faa922a0b1`
        const req_loc_ip = await fetch(url);
        var location = await req_loc_ip.json();
        console.log(location)
        if (location) {
            let region = location.region.toLowerCase();
            switch (region) {
                case "sindh": $("input[value='SEQS_']").trigger("click"); break;
                case "punjab": $("input[value='PEQS_']").trigger("click"); break;
                case "kpk": $("input[value='NEQS_']").trigger("click"); break;
            }
            setTimeout(function(){
                $("#loc_err").hide()
            },1000)
          
        }
    }
})
