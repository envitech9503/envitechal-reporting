    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
    <!-- For mobile menu toggle functionality -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const menuButton = document.getElementById('menu-button');
            const sidebar = document.getElementById('sidebar');
            
            menuButton.addEventListener('click', function() {
                sidebar.classList.toggle('-translate-x-full');
                sidebar.classList.toggle('transform-none');
            });
        });
    </script>
    <style>
        .NEQS,
        .PEQS {
            display: none;
        }
        
        /* Add this CSS to your stylesheet */
        @media screen and (min-width: 768px) and (max-width: 1024px) {
            .side-nav {
                width: 100%; /* Make the navigation full width */
                left: -100%; /* Hide it off-screen by default */
                transition: left 0.3s ease;
                font-size:15px;
            }

            .side-nav.show {
                left: 0; /* Show the navigation on smaller screens */
            }
        }

        /* Add a hamburger menu icon for mobile */
        @media screen and (min-width: 768px) and (max-width: 1024px) {
            .menu-toggle {
                display: block; /* Show the toggle button on small screens */
            }

            .menu-toggle a {
                cursor: pointer;
            }
        }

        /* You can style the hamburger icon as you like */
        .menu-toggle i {
            font-size: 24px;
            margin-right: 10px;
        }

        /* Add this CSS to make the submenus visible on mobile */
        @media screen and (min-width: 768px) and (max-width: 1024px) {
            .sub-menu.show {
                display: block;
            }
        }
        .table-container {
            width: 100%;
            overflow-x: auto;
        }
        table {
            min-width: 800px;
        }
        .water-form-table {
        table-layout: fixed;
        width: 100%;
    }
    .water-form-table td, .water-form-table th {
        word-wrap: break-word;
        overflow-wrap: break-word;
        padding: 8px;
    }
    
    
    
    /* Make inputs fill their containers */
    .water-form-table input {
        width: 100%;
        box-sizing: border-box;
    }
    </style>
</head>
<body class="bg-gray-100 font-sans">
